# Supabase — credenciais públicas usadas pelo Next.js
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Proteção antiabuso — segredo de servidor com no mínimo 32 caracteres aleatórios
ABUSE_FINGERPRINT_SECRET=
# Compatibilidade temporária; remova após migrar o painel do Netlify.
# REPORT_FINGERPRINT_SECRET=

# Sentry — DSN público no cliente e DSN opcional exclusivo do servidor
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Status operacional
STATUS_STALE_AFTER_HOURS=384

# Scraper/CI privilegiado — nunca usar NEXT_PUBLIC_
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SCRAPER_TRIGGER_SOURCE=local
